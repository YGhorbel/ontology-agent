# --- LLM provider (only needed for the LIVE CLI run; tests never read these) ---
# Provider is swappable: "openai" (default) or "azure".
LLM_PROVIDER=openai
LLM_TEMPERATURE=0.1

# Option A — plain OpenAI:
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# Option B — Azure OpenAI (set LLM_PROVIDER=azure above). The DEPLOYMENT name is
# your model. The endpoint host "<instance>.openai.azure.com" -> instance name.
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_API_INSTANCE_NAME=my-azure-resource
AZURE_OPENAI_API_DEPLOYMENT_NAME=my-gpt-4o-mini-deployment
AZURE_OPENAI_API_VERSION=2024-10-21

# --- LangSmith tracing (optional; if unset, the run still works, just untraced) ---
# Current canonical names:
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=ls-...
LANGSMITH_PROJECT=ontology-generator
# Legacy aliases (still honored by the SDK; set EITHER family, not both):
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls-...
LANGCHAIN_PROJECT=ontology-generator

# --- Databases (docker-compose provides both) ---
# Ontology store (where generated fragments are persisted):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ontology_dev
# Target datasource to introspect:
ONTOLOGY_TARGET_DSN=postgresql://postgres:postgres@localhost:5432/ecommerce

# --- Tests ---
# Set to enable the gated end-to-end test (test/agent.test.ts):
E2E_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce

# Output directory for JSON-LD files:
OUT_DIR=out
